# Drafts Receiver environment template
# Copy to .env and fill in values

# SAP — server-level bearer token (64 hex chars)
BEARER_TOKEN=your_server_pass_secret_here

# Path to state.json (project registry)
STATE_FILE=/var/www/beta.labs.vc/drafts/.state.json

# Base domain for generated URLs
PUBLIC_BASE=https://your.domain

# Port for receiver (nginx proxies here)
PORT=3100

# Redis for rate limiting (optional, uses in-memory if not set)
REDIS_URL=redis://127.0.0.1:6379

# GitHub token for GitHub-backed project sync (optional)
GITHUB_TOKEN_PATH=/etc/labs/github_token
