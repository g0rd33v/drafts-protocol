# Master Access Pass — the single secret that grants root control.
# Generate with: openssl rand -hex 32
BEARER_TOKEN=your-64-char-hex-master-token-here

# GitHub Personal Access Token with 'repo' scope (optional — for sync feature)
GITHUB_TOKEN=
GITHUB_USER=your-github-username

# Where project folders live on disk
DRAFTS_DIR=/var/www/beta.labs.vc/drafts

# Internal port the receiver listens on (nginx proxies from public 443)
PORT=3100

# Public origin the instruction pages embed in links
PUBLIC_BASE_URL=https://beta.labs.vc
